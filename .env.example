# ─── Supabase ─────────────────────────────────────────────────────
# Dapatkan dari: https://supabase.com/dashboard/project/[ID]/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── Gemini API (untuk Chatbot) ────────────────────────────────────
# Dapatkan dari: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ─── OpenRouter API (untuk Face AI Mood Tracker & Dermatologi AI) ──
# Dapatkan dari: https://openrouter.ai/keys
# Digunakan untuk: Face Mood Tracker (Gemini 2.5 Flash) + Dermatologi AI (Claude Opus)
VITE_GEMINI_FACE_API_KEY=your-openrouter-api-key-here
